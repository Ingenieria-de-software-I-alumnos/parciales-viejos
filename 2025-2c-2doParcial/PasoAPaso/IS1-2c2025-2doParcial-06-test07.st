!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 10:57:08'!
test01

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login'.
	
	self assert: (unaHistoria tieneNombre: 'Implementar login').
	self assert: (unaHistoria tienePrioridadMedia).! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 10:59:19'!
test02

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login' conPrioridad: #PrioridadAlta.
	
	self deny: (unaHistoria tienePrioridadMedia).
	self assert: (unaHistoria tienePrioridadAlta).! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 11:06:08'!
test03

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login' conPrioridad: #PrioridadAlta conResponsables: (Set with: 'Juan Perez').
	
	self assert: (unaHistoria tieneComoResponsableA: 'Juan Perez').! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 11:37:03'!
test04

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login'.
	
	unaHistoria agregarResponsables: (Set with: 'Juan Perez').
	
	self assert: (unaHistoria tieneComoResponsableA: 'Juan Perez').! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 11:37:49'!
test05

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login'.
	
	unaHistoria agregarResponsables: (Set with: 'Juan Perez').
	unaHistoria agregarResponsables: (Set with: 'Maria Gomez').
	
	self assert: (unaHistoria tieneComoResponsableA: 'Juan Perez').
	self assert: (unaHistoria tieneComoResponsableA: 'Maria Gomez').! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 11:40:22'!
test06

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login' conPrioridad: #PrioridadBaja conResponsables: (Set with: 'Juan Perez').
	
	self assert: (unaHistoria nombre) equals: 'Implementar login'.
	self assert: (unaHistoria prioridad) equals: #PrioridadBaja.
	self assert: (unaHistoria responsables) equals: (Set with: 'Juan Perez').! !

!TestKanban methodsFor: 'as yet unclassified' stamp: 'LL 11/17/2025 15:34:53'!
test07

	| unaHistoria |
	unaHistoria := HistoriaDeUsuario conNombre: 'Implementar login' conPrioridad: #PrioridadBaja conResponsables: (Set with: 'Juan Perez').
	
	unaHistoria moverA: #EstadoEnProgreso.
	
	self assert: (unaHistoria estaEnEstado: #EstadoEnProgreso).! !
